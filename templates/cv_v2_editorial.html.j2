<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ cv.basics.name }} - CV (Editorial)</title>
    <style>
{{ style_css | safe }}
    </style>
</head>
<body class="variant-{{ variant_key }} {{ fit_class }}">
    <div class="page">
        <h1 class="name">{{ cv.basics.name }}</h1>
        <h2 class="title">{{ cv.basics.label }}</h2>
        <div class="header-divider"></div>

        <div class="contact-grid">
            <div class="contact-item"><span class="contact-label">Location</span><span class="contact-value">{{ cv.basics.location }}</span></div>
            <div class="contact-item"><span class="contact-label">Telephone</span><span class="contact-value">{{ cv.basics.phone }}</span></div>
            <div class="contact-item"><span class="contact-label">Email</span><span class="contact-value">{{ cv.basics.email }}</span></div>
            {% if cv.profiles.website.url %}<div class="contact-item"><span class="contact-label">Website</span><span class="contact-value"><a href="{{ cv.profiles.website.url }}">{{ cv.profiles.website.username }}</a></span></div>{% endif %}
            {% if cv.profiles.linkedin.url %}<div class="contact-item"><span class="contact-label">LinkedIn</span><span class="contact-value"><a href="{{ cv.profiles.linkedin.url }}">{{ cv.profiles.linkedin.username }}</a></span></div>{% endif %}
            {% if cv.profiles.github.url %}<div class="contact-item"><span class="contact-label">Github</span><span class="contact-value"><a href="{{ cv.profiles.github.url }}">{{ cv.profiles.github.username }}</a></span></div>{% endif %}
        </div>

        {% if cv.introduction %}
        <h3 class="section-heading">Profile</h3>
        <p class="introduction">{{ cv.introduction }}</p>
        {% endif %}

        {% if page1.experience %}
        <h3 class="section-heading">Professional Experience</h3>
        {% for job in page1.experience %}
        <div class="experience-item">
            {% if job.logo_uri %}<img class="company-logo" src="{{ job.logo_uri }}" alt="{{ job.company }} logo" />{% endif %}
            <div class="job-title">{{ job.position }}<br>{{ job.company }}{% if job.location %}, {{ job.location }}{% endif %}</div>
            <div class="job-period">{{ job.startDate }} - {{ job.endDate }}</div>
            {% if job.highlights %}
            <div class="job-description"><ul>{% for point in job.highlights %}<li>{{ point }}</li>{% endfor %}</ul></div>
            {% endif %}
        </div>
        {% endfor %}
        {% endif %}

        {% if page1.education %}
        <h3 class="section-heading">Education</h3>
        {% for edu in page1.education %}
        <div class="education-item">
            {% if edu.logo_uri %}<img class="edu-logo" src="{{ edu.logo_uri }}" alt="{{ edu.institution }} logo" />{% endif %}
            <div class="edu-details">
                <div class="degree">{{ edu.area }}, {{ edu.institution }}</div>
                <div class="edu-period">{{ edu.date }}{% if edu.grade %}, {{ edu.grade }}{% endif %}</div>
            </div>
        </div>
        {% endfor %}
        {% endif %}

        <div class="page-number">Page 1 of 2</div>
    </div>

    <div class="page">
        {% if page2.experience %}
        <h3 class="section-heading" style="margin-top: 0;">Professional Experience</h3>
        {% for job in page2.experience %}
        <div class="experience-item">
            {% if job.logo_uri %}<img class="company-logo" src="{{ job.logo_uri }}" alt="{{ job.company }} logo" />{% endif %}
            <div class="job-title">{{ job.position }}<br>{{ job.company }}{% if job.location %}, {{ job.location }}{% endif %}</div>
            <div class="job-period">{{ job.startDate }} - {{ job.endDate }}</div>
            {% if job.highlights %}
            <div class="job-description"><ul>{% for point in job.highlights %}<li>{{ point }}</li>{% endfor %}</ul></div>
            {% endif %}
        </div>
        {% endfor %}
        {% endif %}

        {% if page2.education %}
        <h3 class="section-heading">Education</h3>
        {% for edu in page2.education %}
        <div class="education-item">
            {% if edu.logo_uri %}<img class="edu-logo" src="{{ edu.logo_uri }}" alt="{{ edu.institution }} logo" />{% endif %}
            <div class="edu-details">
                <div class="degree">{{ edu.area }}, {{ edu.institution }}</div>
                <div class="edu-period">{{ edu.date }}{% if edu.grade %}, {{ edu.grade }}{% endif %}</div>
            </div>
        </div>
        {% endfor %}
        {% endif %}

        {% if page2.skills %}
        <h3 class="section-heading">Core Competencies</h3>
        <div class="skills-grid">
            {% for skill in page2.skills %}
            <div>
                <div class="skill-category">{{ skill.category }}</div>
                <div class="skill-list">{{ skill.keywords }}</div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if page2.volunteers %}
        <h3 class="section-heading">Community Engagement</h3>
        {% for role in page2.volunteers %}
        <div class="volunteer-item">
            {% if role.logo_uri %}<img class="org-logo" src="{{ role.logo_uri }}" alt="{{ role.organization }} logo" />{% endif %}
            <div class="volunteer-details">
                <div class="volunteer-title">{{ role.position }}, {{ role.organization }}</div>
                <div class="volunteer-period">{{ role.period }}</div>
            </div>
        </div>
        {% endfor %}
        {% endif %}

        {% if page2.certifications %}
        <h3 class="section-heading">Professional Certifications</h3>
        <ol class="cert-list">{% for cert in page2.certifications %}<li>{{ cert }}</li>{% endfor %}</ol>
        {% endif %}

        {% if page2.languages %}
        <h3 class="section-heading">Languages</h3>
        <ol class="lang-list">{% for lang in page2.languages %}<li>{{ lang | safe }}</li>{% endfor %}</ol>
        {% endif %}

        <div class="page-number">Page 2 of 2</div>
    </div>
</body>
</html>
